def write_summary_sheet(wb, summary_rows):
    ws = wb.active
    ws.title = "Summary of Results"
    headers = [
        "Config Tab Name",
        "Exports Tab Name",
        "Result",
        "Config Unmatched Rows",
        "Input File Unmatched Rows",
        "Column Mismatched",
    ]
    ws.append(headers)
    for col in range(1, len(headers) + 1):
        style_header_cell(ws.cell(row=1, column=col))

    for r in summary_rows:
        row_values = [
            r.get("config_tab", ""),
            r.get("export_tab", ""),
            r.get("result", ""),
            r.get("config_unmatched_rows", "NA"),
            r.get("export_unmatched_rows", "NA"),
            r.get("col_mismatch", "NA"),
        ]
        ws.append(row_values)
        result_row = ws.max_row
        result_value = r.get("result", "")
        for col in range(1, len(headers) + 1):
            cell = ws.cell(row=result_row, column=col)
            style_data_cell(cell)
        result_cell = ws.cell(row=result_row, column=3)
        if result_value in RESULT_COLORS:
            result_cell.fill = RESULT_COLORS[result_value]
            result_cell.font = RESULT_FONT_COLORS[result_value]

    last_col_letter = get_column_letter(len(headers))
    ws.auto_filter.ref = f"A1:{last_col_letter}{ws.max_row}"
    ws.freeze_panes = "A2"
    ws.row_dimensions[1].height = 22

    autofit_columns(ws)


def write_detail_sheet(wb, sheet_name, config_tab, export_tab, cfg_df, exp_df, existing_names,
                        red_config_cols=None, red_export_cols=None, row_label="Unmatched Rows"):
    red_config_cols = red_config_cols or set()
    red_export_cols = red_export_cols or set()

    tab_name = sanitize_sheet_name(sheet_name, existing_names)
    existing_names.add(tab_name)
    dsheet = wb.create_sheet(tab_name)

    cfg_cols = list(cfg_df.columns) if cfg_df is not None else []
    exp_cols = list(exp_df.columns) if exp_df is not None else []

    left_width = max(len(cfg_cols), 1)
    gap = 2
    start_col_right = left_width + gap + 1

    # ---- Left table: Config source ----
    label_left = f"Source: Config Tab '{config_tab}' - {row_label}"
    dsheet.cell(row=1, column=1, value=label_left)
    dsheet.cell(row=1, column=1).font = SOURCE_FONT
    dsheet.cell(row=1, column=1).fill = SOURCE_FILL
    if left_width > 1:
        dsheet.merge_cells(start_row=1, start_column=1, end_row=1, end_column=left_width)
        for c in range(1, left_width + 1):
            dsheet.cell(row=1, column=c).fill = SOURCE_FILL

    for j, col in enumerate(cfg_cols, start=1):
        cell = dsheet.cell(row=2, column=j, value=col)
        if col in red_config_cols:
            style_unmatched_header_cell(cell)
        else:
            style_header_cell(cell)
    if cfg_df is not None and not cfg_df.empty:
        for i, row in enumerate(cfg_df.itertuples(index=False), start=3):
            for j, val in enumerate(row, start=1):
                cell = dsheet.cell(row=i, column=j, value=val)
                style_data_cell(cell)

    # ---- Right table: Export source ----
    label_right = f"Source: Export Tab '{export_tab}' - {row_label}"
    dsheet.cell(row=1, column=start_col_right, value=label_right)
    dsheet.cell(row=1, column=start_col_right).font = SOURCE_FONT
    dsheet.cell(row=1, column=start_col_right).fill = SOURCE_FILL
    right_width = max(len(exp_cols), 1)
    if right_width > 1:
        dsheet.merge_cells(
            start_row=1, start_column=start_col_right,
            end_row=1, end_column=start_col_right + right_width - 1
        )
        for c in range(start_col_right, start_col_right + right_width):
            dsheet.cell(row=1, column=c).fill = SOURCE_FILL

    for j, col in enumerate(exp_cols, start=start_col_right):
        cell = dsheet.cell(row=2, column=j, value=col)
        if col in red_export_cols:
            style_unmatched_header_cell(cell)
        else:
            style_header_cell(cell)
    if exp_df is not None and not exp_df.empty:
        for i, row in enumerate(exp_df.itertuples(index=False), start=3):
            for j, val in enumerate(row, start=start_col_right):
                cell = dsheet.cell(row=i, column=j, value=val)
                style_data_cell(cell)

    dsheet.freeze_panes = "A3"
    dsheet.row_dimensions[1].height = 20
    autofit_columns(dsheet)


def write_report(summary_rows, detail_sheets, output_folder, state_name):
    wb = Workbook()
    write_summary_sheet(wb, summary_rows)

    existing_names = {"Summary of Results"}
    for tab_key, res in detail_sheets.items():
        has_col_mismatch = res.get("col_mismatch", "NA") != "NA"
        row_label = "Full Table (column mismatch - manual review)" if has_col_mismatch else "Unmatched Rows"
        write_detail_sheet(
            wb,
            tab_key,
            res.get("config_tab", tab_key),
            res.get("export_tab", ""),
            res["unmatched_config_df"],
            res["unmatched_export_df"],
            existing_names,
            red_config_cols=res.get("red_config_cols", set()),
            red_export_cols=res.get("red_export_cols", set()),
            row_label=row_label,
        )

    os.makedirs(output_folder, exist_ok=True)
    ts = datetime.now().strftime("%Y%m%d_%H%M%S")
    state_part = f"_{state_name}" if state_name else ""
    out_path = os.path.join(output_folder, f"Comparison_Report{state_part}_{ts}.xlsx")
    wb.save(out_path)
    return out_path


# ------------------------------------------------------------------
# Main
# ------------------------------------------------------------------
def main(input_file):
    paths, input_wb = load_input_paths(input_file)

    raw_decimal = paths.get("decimal_places")
    try:
        decimal_places = int(raw_decimal) if raw_decimal is not None and str(raw_decimal).strip() != "" else None
    except (ValueError, TypeError):
        print(f"WARNING: Could not parse decimal places from Inputs!C8 (value: {raw_decimal!r}). "
              f"Proceeding without rounding.")
        decimal_places = None
    if decimal_places is not None:
        print(f"Numeric values will be rounded to {decimal_places} decimal place(s) before comparison.")

    eq_tab_map = load_tab_name_mapping(input_wb, RATE_VAR_SHEET, RATE_VAR_FILE_COL, RATE_VAR_CONFIG_COL)

    tr_pairs = load_mapping_pairs_from_sheet(input_wb, COL_MATCH_TR_SHEET, MAPPING_FILE_COL, MAPPING_CONFIG_COL)
    tr_synonyms = build_synonym_groups(tr_pairs)
    eq_synonyms = build_synonym_groups(EQ_COLUMN_SYNONYM_PAIRS)
    radar_synonyms = build_synonym_groups(RADAR_COLUMN_SYNONYM_PAIRS)

    # Value-level synonym groups (not column-name synonyms) applied only to
    # the Roof Limit tab's "Limit" column.
    limit_value_synonyms = build_synonym_groups(LIMIT_VALUE_SYNONYM_PAIRS)
    roof_value_synonym_cols = {clean_col(ROOF_LIMIT_VALUE_COLUMN): limit_value_synonyms}

    config_wb = load_workbook(paths["config_file"], data_only=True)
    config_tabs = config_wb.sheetnames

    summary_rows = []
    detail_sheets = {}
    matched_config_tabs = set()

    # ---------------- Radar ----------------
    try:
        radar_wb = load_workbook(paths["radar_file"], data_only=True)
        for sheet_name in radar_wb.sheetnames:
            resolved_cfg = resolve_name(sheet_name, config_tabs)
            if resolved_cfg:
                config_df = read_df(paths["config_file"], resolved_cfg, 1)
                export_df = read_df(paths["radar_file"], sheet_name, 1)
                res = process_pair(config_df, export_df, resolved_cfg, sheet_name, radar_synonyms, decimal_places)
                matched_config_tabs.add(resolved_cfg)
                summary_rows.append(res)
                if res["result"] != VALIDATED:
                    detail_sheets[resolved_cfg] = res
            else:
                summary_rows.append(missing_row(export_tab=sheet_name, result=MISSING_IN_CONFIG))
    except Exception as e:
        print(f"WARNING: Radar file processing failed: {e}")

    # ---------------- EQ ----------------
    try:
        eq_wb = load_workbook(paths["eq_file"], data_only=True)
        for sheet_name in eq_wb.sheetnames:
            target_config_tab = resolve_name(sheet_name, config_tabs)
            if not target_config_tab:
                mapped_raw = eq_tab_map.get(clean_col(sheet_name))
                if mapped_raw:
                    target_config_tab = resolve_name(mapped_raw, config_tabs)

            if target_config_tab:
                header_row = detect_eq_header_row(eq_wb[sheet_name])
                config_df = read_df(paths["config_file"], target_config_tab, 1)
                # NOTE: uses read_df_first_table -- an EQ sheet may contain
                # multiple tables side by side; only the first is kept
                # (truncated at the first blank/empty header cell).
                export_df = read_df_first_table(paths["eq_file"], sheet_name, header_row)
                res = process_pair(config_df, export_df, target_config_tab, sheet_name, eq_synonyms, decimal_places)
                matched_config_tabs.add(target_config_tab)
                summary_rows.append(res)
                if res["result"] != VALIDATED:
                    detail_sheets[target_config_tab] = res
            else:
                summary_rows.append(missing_row(export_tab=sheet_name, result=MISSING_IN_CONFIG))
    except Exception as e:
        print(f"WARNING: EQ file processing failed: {e}")

    # ---------------- Territory (+ supplemental C56 file) ----------------
    try:
        resolved_terr_cfg = resolve_name(TERRITORY_CONFIG_TAB, config_tabs)
        if resolved_terr_cfg:
            config_df = read_df(paths["config_file"], resolved_terr_cfg, 1)

            terr_wb1 = load_workbook(paths["territory_file"], data_only=True)
            sheet1_name = terr_wb1.sheetnames[0]
            export_df1 = read_df(paths["territory_file"], sheet1_name, 1)

            export_tab_label = sheet1_name
            combined_export_df = export_df1

            territory_file2_path = paths.get("territory_file2")
            if territory_file2_path:
                terr_wb2 = load_workbook(territory_file2_path, data_only=True)
                sheet2_name = terr_wb2.sheetnames[0]
                export_df2 = read_df(territory_file2_path, sheet2_name, 1)
                # NOTE: merges specifically on the "Territory" column present
                # in both files (not just any shared column name).
                combined_export_df = merge_export_dataframes(
                    export_df1, export_df2, TERRITORY_MERGE_COLUMN
                )
                export_tab_label = f"{sheet1_name} + {sheet2_name}"

            res = process_pair(
                config_df, combined_export_df, resolved_terr_cfg, export_tab_label, tr_synonyms, decimal_places
            )
            matched_config_tabs.add(resolved_terr_cfg)
            summary_rows.append(res)
            if res["result"] != VALIDATED:
                detail_sheets[resolved_terr_cfg] = res
        else:
            summary_rows.append(missing_row(export_tab="Sheet1", result=MISSING_IN_CONFIG))
    except Exception as e:
        print(f"WARNING: Territory file processing failed: {e}")

    # ---------------- Roof Limit ----------------
    try:
        resolved_roof_cfg = resolve_name(ROOF_CONFIG_TAB, config_tabs)
        if resolved_roof_cfg:
            config_df = read_df(paths["config_file"], resolved_roof_cfg, 1)
            roof_wb = load_workbook(paths["roof_file"], data_only=True)
            roof_sheet_name = roof_wb.sheetnames[0]
            export_df = read_df(paths["roof_file"], roof_sheet_name, 1)
            # NOTE: passes roof_value_synonym_cols so "No Limit" (Config) and
            # "No Sub-limit" (export) are treated as equal in the "Limit" column.
            res = process_pair(
                config_df, export_df, resolved_roof_cfg, roof_sheet_name, None,
                decimal_places, roof_value_synonym_cols
            )
            matched_config_tabs.add(resolved_roof_cfg)
            summary_rows.append(res)
            if res["result"] != VALIDATED:
                detail_sheets[resolved_roof_cfg] = res
        else:
            summary_rows.append(missing_row(export_tab="Sheet1", result=MISSING_IN_CONFIG))
    except Exception as e:
        print(f"WARNING: Roof Limit file processing failed: {e}")

    # ---------------- Config tabs never matched by any export ----------------
    for tab in config_tabs:
        if tab not in matched_config_tabs:
            summary_rows.append(missing_row(config_tab=tab, result=MISSING_IN_EXPORT))

    out_path = write_report(summary_rows, detail_sheets, paths["output_folder"], paths["state_name"])
    print(f"Report saved to: {out_path}")
    return out_path


if __name__ == "__main__":
    main(INPUT_FILE_PATH)
