# Helpers
# ------------------------------------------------------------------
def clean_col(name):
    if name is None:
        return ""
    return re.sub(r"[^a-z0-9]", "", str(name).strip().lower())


def resolve_name(target, names):
    """Case/whitespace/punctuation-insensitive lookup of `target` within `names`.
    Returns the actual (raw) name from `names` if found, else None."""
    if target is None:
        return None
    tc = clean_col(target)
    for n in names:
        if clean_col(n) == tc:
            return n
    return None


def sanitize_sheet_name(name, existing):
    name = re.sub(r"[:\\/?*\[\]]", "_", str(name)).strip()[:31]
    if not name:
        name = "Sheet"
    base, i = name, 1
    while name in existing:
        suffix = f"_{i}"
        name = base[: 31 - len(suffix)] + suffix
        i += 1
    return name


def detect_eq_header_row(ws):
    a1 = ws.cell(row=1, column=1).value
    a2 = ws.cell(row=2, column=1).value
    if a1 not in (None, ""):
        return 1
    if a2 not in (None, ""):
        return 2
    return 3


def read_df(file_path, sheet_name, header_row=1):
    """Standard reader -- drops any 'Unnamed' (blank-header) columns wherever
    they occur. Used for Config tabs, Radar, Territory, Roof Limit."""
    df = pd.read_excel(file_path, sheet_name=sheet_name, header=header_row - 1, dtype=str)
    df = df.loc[:, ~df.columns.astype(str).str.startswith("Unnamed")]
    df.columns = [str(c).strip() for c in df.columns]
    df = df.dropna(how="all").reset_index(drop=True)
    return df


def read_df_first_table(file_path, sheet_name, header_row=1):
    """EQ-only reader. An EQ sheet may contain multiple tables laid out side
    by side on the same header row (e.g. a second table's headers starting
    a few columns after the first table ends, with a blank column acting as
    a separator). This reads starting at the detected header row, then
    truncates at the FIRST blank/empty header cell -- everything from that
    column onward (the next table) is discarded, and only the first table's
    columns/data are kept."""
    df = pd.read_excel(file_path, sheet_name=sheet_name, header=header_row - 1, dtype=str)

    boundary = len(df.columns)
    for i, c in enumerate(df.columns):
        c_str = "" if c is None else str(c).strip()
        if c_str == "" or c_str.lower().startswith("unnamed"):
            boundary = i
            break

    df = df.iloc[:, :boundary]
    df.columns = [str(c).strip() for c in df.columns]
    df = df.dropna(how="all").reset_index(drop=True)
    return df


def normalize_value(v, decimal_places=None, value_synonym_groups=None):
    if v is None or (isinstance(v, float) and pd.isna(v)):
        return ""
    s = str(v).strip()

    if value_synonym_groups:
        cs = clean_col(s)
        if cs in value_synonym_groups:
            # Return the shared group id so both synonymous values normalize
            # to the exact same string.
            return f"__SYN__{value_synonym_groups[cs]}"

    try:
        f = float(s)
        if decimal_places is not None:
            f = round(f, decimal_places)
        if f.is_integer():
            return str(int(f))
        if decimal_places is not None:
            return f"{f:.{decimal_places}f}".rstrip("0").rstrip(".")
        return str(f)
    except ValueError:
        return s.lower()


def find_header_index(headers, target):
    """Case/whitespace-insensitive header lookup. Returns index or None."""
    target_clean = clean_col(target)
    for i, h in enumerate(headers):
        if clean_col(h) == target_clean:
            return i
    return None


def find_sheet_name(wb, target):
    return resolve_name(target, wb.sheetnames)


# ------------------------------------------------------------------
# Synonym-group based mapping (used for BOTH column names and values)
# ------------------------------------------------------------------
def build_synonym_groups(pairs):
    """
    pairs: list of (name_a, name_b) tuples meaning "these refer to the same
    field/value". Entries that share a name are chained together
    transitively (union-find).
    Returns dict: {clean_col(name): group_id}
    """
    parent = {}

    def find(x):
        parent.setdefault(x, x)
        while parent[x] != x:
            parent[x] = parent[parent[x]]
            x = parent[x]
        return x

    def union(x, y):
        rx, ry = find(x), find(y)
        if rx != ry:
            parent[rx] = ry

    for a, b in pairs:
        ca, cb = clean_col(a), clean_col(b)
        if not ca or not cb:
            continue
        find(ca)
        find(cb)
        union(ca, cb)

    return {k: find(k) for k in parent}


def load_mapping_pairs_from_sheet(wb, sheet_name, file_col_header, config_col_header):
    """Reads a 2-column mapping sheet and returns list of (config_val, file_val) tuples."""
    resolved_name = find_sheet_name(wb, sheet_name)
    if resolved_name is None:
        print(f"WARNING: Sheet '{sheet_name}' not found (available sheets: {wb.sheetnames}). "
              f"Skipping this mapping.")
        return []
    ws = wb[resolved_name]
    headers = [c.value for c in next(ws.iter_rows(min_row=1, max_row=1))]
    file_idx = find_header_index(headers, file_col_header)
    config_idx = find_header_index(headers, config_col_header)
    if file_idx is None or config_idx is None:
        print(f"WARNING: Could not find '{file_col_header}'/'{config_col_header}' "
              f"headers in '{sheet_name}' (found headers: {headers}). Skipping this mapping.")
        return []
    pairs = []
    for row in ws.iter_rows(min_row=2, values_only=True):
        f, c = row[file_idx], row[config_idx]
        if f and c:
            pairs.append((str(c).strip(), str(f).strip()))
    return pairs


def load_tab_name_mapping(wb, sheet_name, file_col_header, config_col_header):
    """Returns dict: {clean_col(export_tab_name): raw_config_tab_name}"""
    resolved_name = find_sheet_name(wb, sheet_name)
    if resolved_name is None:
        print(f"WARNING: Sheet '{sheet_name}' not found (available sheets: {wb.sheetnames}). "
              f"Skipping this mapping.")
        return {}
    ws = wb[resolved_name]
    headers = [c.value for c in next(ws.iter_rows(min_row=1, max_row=1))]
    file_idx = find_header_index(headers, file_col_header)
    config_idx = find_header_index(headers, config_col_header)
    if file_idx is None or config_idx is None:
        print(f"WARNING: Could not find '{file_col_header}'/'{config_col_header}' "
              f"headers in '{sheet_name}' (found headers: {headers}). Skipping this mapping.")
        return {}
    mapping = {}
    for row in ws.iter_rows(min_row=2, values_only=True):
        f, c = row[file_idx], row[config_idx]
        if f and c:
            mapping[clean_col(f)] = str(c).strip()
    return mapping


# ------------------------------------------------------------------
# Column & row comparison
# ------------------------------------------------------------------
def match_columns(config_cols, export_cols, synonym_groups=None):
    """
    synonym_groups: dict {clean_col(name): group_id}, e.g. from build_synonym_groups().
    Returns (matched_pairs, unmatched_config_cols)
    """
    export_clean_map = {clean_col(c): c for c in export_cols}
    matched, unmatched = [], []

    for c in config_cols:
        cc = clean_col(c)
        if cc in export_clean_map:
            matched.append((c, export_clean_map[cc]))
            continue
        if synonym_groups and cc in synonym_groups:
            group_id = synonym_groups[cc]
            found = None
            for ec_clean, ec_raw in export_clean_map.items():
                if synonym_groups.get(ec_clean) == group_id:
                    found = ec_raw
                    break
            if found:
                matched.append((c, found))
                continue
        unmatched.append(c)
    return matched, unmatched


def compare_rows(config_df, export_df, matched_cols, decimal_places=None, value_synonym_cols=None):
    """
    value_synonym_cols: optional dict {clean_col(config_column_name): synonym_groups}
    applying value-level synonyms (e.g. "No Limit" == "No Sub-limit") only to
    specific matched columns.
    """
    value_synonym_cols = value_synonym_cols or {}
    config_cols = [m[0] for m in matched_cols]
    export_cols = [m[1] for m in matched_cols]

    # Per matched-column position, figure out which value-synonym group (if
    # any) applies -- keyed off the CONFIG side column name.
    per_col_synonyms = [value_synonym_cols.get(clean_col(c)) for c in config_cols]

    def build_tuples(df, cols):
        tuples = []
        for row in df[cols].itertuples(index=False):
            t = tuple(
                normalize_value(v, decimal_places, per_col_synonyms[idx])
                for idx, v in enumerate(row)
            )
            tuples.append(t)
        return tuples

    config_tuples = build_tuples(config_df, config_cols)
    export_tuples = build_tuples(export_df, export_cols)

    export_counter = Counter(export_tuples)
    unmatched_config_idx = []
    remaining_export = export_counter.copy()
    for i, t in enumerate(config_tuples):
        if remaining_export.get(t, 0) > 0:
            remaining_export[t] -= 1
        else:
            unmatched_config_idx.append(i)

    config_counter = Counter(config_tuples)
    unmatched_export_idx = []
    remaining_config = config_counter.copy()
    for i, t in enumerate(export_tuples):
        if remaining_config.get(t, 0) > 0:
            remaining_config[t] -= 1
        else:
            unmatched_export_idx.append(i)

    return (
        config_df.iloc[unmatched_config_idx].copy(),
        export_df.iloc[unmatched_export_idx].copy(),
    )


def process_pair(config_df, export_df, config_tab, export_tab, synonym_groups=None,
                  decimal_places=None, value_synonym_cols=None):
    matched_cols, unmatched_config_cols = match_columns(
        list(config_df.columns), list(export_df.columns), synonym_groups
    )
    matched_export_set = {e for _, e in matched_cols}
    unmatched_export_cols = [c for c in list(export_df.columns) if c not in matched_export_set]

    # Row-level diff computed using only the columns we COULD match -- used for
    # the Summary sheet counts (best-effort indicator even when some columns
    # couldn't be aligned).
    if matched_cols:
        diff_config_rows, diff_export_rows = compare_rows(
            config_df, export_df, matched_cols, decimal_places, value_synonym_cols
        )
    else:
        diff_config_rows, diff_export_rows = config_df.copy(), export_df.copy()

    total_col_mismatch = len(unmatched_config_cols) + len(unmatched_export_cols)

    if total_col_mismatch > 0:
        # Columns don't fully align -> dump the FULL tables (all rows, both sides)
        # for manual review, with unmatched column headers flagged red, instead
        # of a partial diff that can misleadingly come back empty.
        detail_config_df = config_df.copy()
        detail_export_df = export_df.copy()
    else:
        detail_config_df = diff_config_rows
        detail_export_df = diff_export_rows

    if len(diff_config_rows) == 0 and len(diff_export_rows) == 0 and total_col_mismatch == 0:
        result = VALIDATED
    else:
        result = MANUAL_VALIDATION

    return {
        "config_tab": config_tab,
        "export_tab": export_tab,
        "result": result,
        "config_unmatched_rows": len(diff_config_rows),
        "export_unmatched_rows": len(diff_export_rows),
        "col_mismatch": total_col_mismatch if total_col_mismatch > 0 else "NA",
        "unmatched_config_df": detail_config_df,
        "unmatched_export_df": detail_export_df,
        "red_config_cols": set(unmatched_config_cols),
        "red_export_cols": set(unmatched_export_cols),
    }


def missing_row(config_tab="", export_tab="", result=""):
    return {
        "config_tab": config_tab,
        "export_tab": export_tab,
        "result": result,
        "config_unmatched_rows": "NA",
        "export_unmatched_rows": "NA",
        "col_mismatch": "NA",
    }


def merge_export_dataframes(df1, df2, merge_column=TERRITORY_MERGE_COLUMN):
    """Combine two export dataframes into one, for Territory's dual-file case.
    Specifically aligns on the "Territory" column (present in both files,
    matched case/space/punctuation-insensitively) -- NOT on just any shared
    column name. Falls back to combining by row position (with a warning) if
    either file is missing that column."""
    col1 = resolve_name(merge_column, df1.columns)
    col2 = resolve_name(merge_column, df2.columns)

    if col1 and col2:
        # Merge on the Territory column; rename df2's key to match df1's key
        # name so pandas merges on a single logical column instead of
        # producing duplicate Territory_x / Territory_y columns.
        df2_renamed = df2.rename(columns={col2: col1})
        return pd.merge(df1, df2_renamed, on=col1, how="outer", suffixes=("_file1", "_file2"))

    print(f"WARNING: Could not find a '{merge_column}' column in both the Territory export "
          f"file and the supplemental file (Inputs!C56) -- combining columns by row position "
          f"instead. Please verify row order matches between the two files.")
    n = max(len(df1), len(df2))
    df1r = df1.reindex(range(n)).reset_index(drop=True)
    df2r = df2.reindex(range(n)).reset_index(drop=True)
    return pd.concat([df1r, df2r], axis=1)


