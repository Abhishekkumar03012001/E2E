' ---- Source workbook / sheets ----
    Set srcWB = ThisWorkbook
    On Error Resume Next
    Set srcWS = srcWB.Worksheets("Current Rates")
    Set srcDiscount = srcWB.Worksheets("Discount")
    On Error GoTo 0

    ' ---- Destination workbook by chosen full path ----
    Set dstWB = GetOrOpenWorkbookByFullPath(dstFullPath)
    If dstWB Is Nothing Then
        MsgBox "Could not open destination workbook:" & vbCrLf & dstFullPath, vbCritical
        Exit Sub
    End If

    ' If "Current Rates" / "Discount" weren't found in ThisWorkbook,
    ' they're likely in the destination workbook itself (source == destination file).
    If srcWS Is Nothing Then
        On Error Resume Next
        Set srcWS = dstWB.Worksheets("Current Rates")
        On Error GoTo 0
        If Not srcWS Is Nothing Then Set srcWB = dstWB
    End If
    If srcDiscount Is Nothing Then
        On Error Resume Next
        Set srcDiscount = dstWB.Worksheets("Discount")
        On Error GoTo 0
    End If

    If srcWS Is Nothing Then
        MsgBox "Source sheet 'Current Rates' not found in either " & ThisWorkbook.Name & " or " & dstWB.Name & ".", vbCritical
        Exit Sub
    End If
    If srcDiscount Is Nothing Then
        MsgBox "Source sheet 'Discount' not found in either " & ThisWorkbook.Name & " or " & dstWB.Name & ".", vbCritical
        Exit Sub
    End If
