import pandas as pd

def read_rndprm_pd(rndprm_excel, rndprm_csv, output_csv):
    # Read only the Excel headers
    col_file = pd.read_excel(rndprm_excel, nrows=0)

    # Read CSV by skipping its existing header
    df_rndprm = pd.read_csv(
        rndprm_csv,
        dtype='object',
        skiprows=1,
        header=None,
        names=col_file.columns
    )

    # Save CSV with the new headers
    df_rndprm.to_csv(output_csv, index=False)

    return df_rndprm

read_rndprm_pd(
    "headers.xlsx",
    "rndprm.csv",
    "rndprm_updated.csv"
)
