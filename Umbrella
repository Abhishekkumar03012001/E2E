Option Explicit

Sub Compare_Workbooks()

    Dim wb1 As Workbook, wb2 As Workbook
    Dim wbResult As Workbook
    Dim ws1 As Worksheet, ws2 As Worksheet
    Dim wsOut As Worksheet, wsSummary As Worksheet
    Dim file1 As Variant, file2 As Variant
    Dim allSheets As Object, shtName As Variant
    Dim summaryRow As Long, i As Long, sName As String
    Dim tempSheet As Worksheet

    ' Sheets to exclude from comparison
    Dim excludeSheets As Object
    Set excludeSheets = CreateObject("Scripting.Dictionary")
    excludeSheets.Add "INPUT", 1
    excludeSheets.Add "CHANGELOG", 1
    excludeSheets.Add "CONTROL", 1
    excludeSheets.Add "FACTOR DEFINITIONS", 1

    Application.ScreenUpdating = False
    Application.DisplayAlerts = False
    Application.Calculation = xlCalculationManual
    Application.EnableEvents = False

    Set wbResult = ThisWorkbook

    Set tempSheet = wbResult.Worksheets.Add
    tempSheet.Name = "_TEMP_DELETE_"

    For i = wbResult.Worksheets.Count To 1 Step -1
        sName = UCase(wbResult.Worksheets(i).Name)
        If sName <> "README" And sName <> "DESC" And sName <> "_TEMP_DELETE_" Then
            wbResult.Worksheets(i).Delete
        End If
    Next i

    Application.DisplayAlerts = True

    file1 = Application.GetOpenFilename("Excel Files (*.xls*), *.xls*", , "Select First Excel File")
    If file1 = False Then GoTo CleanExit

    file2 = Application.GetOpenFilename("Excel Files (*.xls*), *.xls*", , "Select Second Excel File")
    If file2 = False Then GoTo CleanExit

    If LCase(CStr(file1)) = LCase(CStr(file2)) Then
        MsgBox "You selected the same file twice.", vbExclamation
        GoTo CleanExit
    End If

    Set wb1 = Workbooks.Open(CStr(file1), ReadOnly:=True)
    Set wb2 = Workbooks.Open(CStr(file2), ReadOnly:=True)

    Set wsSummary = wbResult.Worksheets.Add(After:=wbResult.Sheets(wbResult.Sheets.Count))
    wsSummary.Name = "Summary"

    With wsSummary.Range("A1:G1")
        .Value = Array("Sheets In Excel 1", "Sheets In Excel 2", "Analyst View", _
                       "Rows In Excel 1", "Rows In Excel 2", "Matched", "Analyst Comment")
        .Font.Bold = True
        .Interior.Color = RGB(68, 114, 196)
        .Font.Color = RGB(255, 255, 255)
    End With
    summaryRow = 2

    Application.DisplayAlerts = False
    On Error Resume Next
    wbResult.Worksheets("_TEMP_DELETE_").Delete
    On Error GoTo 0
    Application.DisplayAlerts = False

    Set allSheets = CreateObject("Scripting.Dictionary")
    For Each ws1 In wb1.Worksheets
        If Not excludeSheets.Exists(UCase(ws1.Name)) Then
            If Not allSheets.Exists(ws1.Name) Then allSheets.Add ws1.Name, 1
        End If
    Next ws1
    For Each ws2 In wb2.Worksheets
        If Not excludeSheets.Exists(UCase(ws2.Name)) Then
            If Not allSheets.Exists(ws2.Name) Then allSheets.Add ws2.Name, 1
        End If
    Next ws2

    For Each shtName In allSheets.Keys

        Dim existsIn1 As Boolean, existsIn2 As Boolean
        existsIn1 = WorksheetExists(CStr(shtName), wb1)
        existsIn2 = WorksheetExists(CStr(shtName), wb2)

        Dim matchedCount As Long, factorMismatchCount As Long, notMatchedCount As Long
        Dim dataRows1 As Long, dataRows2 As Long
        matchedCount = 0 : factorMismatchCount = 0 : notMatchedCount = 0
        dataRows1 = 0 : dataRows2 = 0

        If Not (existsIn1 And existsIn2) Then

            If existsIn1 Then
                Dim arrO1 As Variant
                arrO1 = ReadSheetArray(wb1.Worksheets(CStr(shtName)))
                If Not IsEmpty(arrO1) Then dataRows1 = UBound(arrO1, 1) - 1
            End If
            If existsIn2 Then
                Dim arrO2 As Variant
                arrO2 = ReadSheetArray(wb2.Worksheets(CStr(shtName)))
                If Not IsEmpty(arrO2) Then dataRows2 = UBound(arrO2, 1) - 1
            End If

            WriteSummaryRow wsSummary, summaryRow, shtName, existsIn1, existsIn2, _
                            dataRows1, dataRows2, 0, 0, 0, "Page Not Found"
            summaryRow = summaryRow + 1
            GoTo NextSheet

        End If

        Set ws1 = wb1.Worksheets(CStr(shtName))
        Set ws2 = wb2.Worksheets(CStr(shtName))

        Dim arr1 As Variant, arr2 As Variant
        arr1 = ReadSheetArray(ws1)
        arr2 = ReadSheetArray(ws2)

        If IsEmpty(arr1) And IsEmpty(arr2) Then
            WriteSummaryRow wsSummary, summaryRow, shtName, existsIn1, existsIn2, _
                            0, 0, 0, 0, 0, "Validated"
            summaryRow = summaryRow + 1
            GoTo NextSheet
        End If

        Dim nr1 As Long, nc1 As Long, nr2 As Long, nc2 As Long
        If Not IsEmpty(arr1) Then nr1 = UBound(arr1, 1) : nc1 = UBound(arr1, 2)
        If Not IsEmpty(arr2) Then nr2 = UBound(arr2, 1) : nc2 = UBound(arr2, 2)

        dataRows1 = IIf(nr1 > 1, nr1 - 1, 0)
        dataRows2 = IIf(nr2 > 1, nr2 - 1, 0)

        Dim factorCol1 As Long, factorCol2 As Long
        factorCol1 = 0 : factorCol2 = 0
        Dim hc As Long
        If Not IsEmpty(arr1) Then
            For hc = 1 To nc1
                If LCase(Trim(CStr(arr1(1, hc)))) = "factor" Then factorCol1 = hc
            Next hc
        End If
        If Not IsEmpty(arr2) Then
            For hc = 1 To nc2
                If LCase(Trim(CStr(arr2(1, hc)))) = "factor" Then factorCol2 = hc
            Next hc
        End If

        Dim hasFactor As Boolean
        hasFactor = (factorCol1 > 0) And (factorCol2 > 0)

        Dim dict1Keys As Object, dict1Factor As Object
        Dim dict2Keys As Object, dict2Factor As Object
        Set dict1Keys = CreateObject("Scripting.Dictionary")
        Set dict1Factor = CreateObject("Scripting.Dictionary")
        Set dict2Keys = CreateObject("Scripting.Dictionary")
        Set dict2Factor = CreateObject("Scripting.Dictionary")

        Dim r As Long
        Dim key As String, factorVal As String

        If Not IsEmpty(arr1) Then
            For r = 2 To nr1
                If IsBlankRow(arr1, r, nc1) Then GoTo SkipDict1
                If hasFactor Then
                    key = BuildKeySkipCol(arr1, r, nc1, factorCol1)
                    factorVal = NormalizeVal(arr1(r, factorCol1))
                Else
                    key = BuildKeyFromArray(arr1, r, nc1)
                    factorVal = ""
                End If
                If Not dict1Keys.Exists(key) Then
                    dict1Keys.Add key, r
                    dict1Factor.Add key, factorVal
                End If
SkipDict1:
            Next r
        End If

        If Not IsEmpty(arr2) Then
            For r = 2 To nr2
                If IsBlankRow(arr2, r, nc2) Then GoTo SkipDict2
                If hasFactor Then
                    key = BuildKeySkipCol(arr2, r, nc2, factorCol2)
                    factorVal = NormalizeVal(arr2(r, factorCol2))
                Else
                    key = BuildKeyFromArray(arr2, r, nc2)
                    factorVal = ""
                End If
                If Not dict2Keys.Exists(key) Then
                    dict2Keys.Add key, r
                    dict2Factor.Add key, factorVal
                End If
SkipDict2:
            Next r
        End If

        Dim rKey As Variant
        Dim f1 As String, f2 As String

        For Each rKey In dict1Keys.Keys
            If Not IsBlankRow(arr1, dict1Keys(rKey), nc1) Then
                If dict2Keys.Exists(rKey) Then
                    If hasFactor Then
                        f1 = NormalizeVal(dict1Factor(rKey))
                        f2 = NormalizeVal(dict2Factor(rKey))
                        If f1 = f2 Then
                            matchedCount = matchedCount + 1
                        Else
                            factorMismatchCount = factorMismatchCount + 1
                        End If
                    Else
                        matchedCount = matchedCount + 1
                    End If
                Else
                    notMatchedCount = notMatchedCount + 1
                End If
            End If
        Next rKey

        For Each rKey In dict2Keys.Keys
            If Not dict1Keys.Exists(rKey) Then
                If Not IsBlankRow(arr2, dict2Keys(rKey), nc2) Then
                    notMatchedCount = notMatchedCount + 1
                End If
            End If
        Next rKey

        Dim analystView As String
        If notMatchedCount > 0 Or factorMismatchCount > 0 Then
            analystView = "Manual Validation Required"
        Else
            analystView = "Validated"
        End If

        WriteSummaryRow wsSummary, summaryRow, shtName, existsIn1, existsIn2, _
                        dataRows1, dataRows2, matchedCount, factorMismatchCount, _
                        notMatchedCount, analystView
        summaryRow = summaryRow + 1

        If notMatchedCount = 0 And factorMismatchCount = 0 Then GoTo NextSheet

        Set wsOut = wbResult.Worksheets.Add(After:=wbResult.Sheets(wbResult.Sheets.Count))
        wsOut.Name = SafeSheetName(CStr(shtName), wbResult)

        Dim e1Start As Long, statusColOut As Long, e2Start As Long
        e1Start = 1
        statusColOut = nc1 + 3
        e2Start = statusColOut + 3

        WriteLabel wsOut, 1, e1Start, "EXCEL 1 - " & CStr(shtName), RGB(68, 114, 196)
        WriteLabel wsOut, 1, statusColOut, "STATUS", RGB(255, 192, 0)
        WriteLabel wsOut, 1, e2Start, "EXCEL 2 - " & CStr(shtName), RGB(68, 114, 196)

        If Not IsEmpty(arr1) Then WriteHeaderRow wsOut, arr1, 2, e1Start, nc1
        With wsOut.Cells(2, statusColOut)
            .Value = "STATUS"
            .Font.Bold = True
            .Interior.Color = RGB(255, 192, 0)
            .Font.Color = RGB(0, 0, 0)
        End With
        If Not IsEmpty(arr2) Then WriteHeaderRow wsOut, arr2, 2, e2Start, nc2

        Dim outRow As Long
        outRow = 3
        Dim c As Long
        Dim statusText As String, statusBg As Long, statusFg As Long

        For Each rKey In dict1Keys.Keys
            r = dict1Keys(rKey)
            If IsBlankRow(arr1, r, nc1) Then GoTo SkipE1Row

            If dict2Keys.Exists(rKey) Then
                If hasFactor Then
                    f1 = NormalizeVal(dict1Factor(rKey))
                    f2 = NormalizeVal(dict2Factor(rKey))
                    If f1 = f2 Then
                        statusText = "MATCHED"
                        statusBg = RGB(198, 239, 206)
                        statusFg = RGB(0, 97, 0)
                    Else
                        statusText = "FACTOR NOT MATCHED"
                        statusBg = RGB(255, 235, 156)
                        statusFg = RGB(156, 87, 0)
                    End If
                Else
                    statusText = "MATCHED"
                    statusBg = RGB(198, 239, 206)
                    statusFg = RGB(0, 97, 0)
                End If
            Else
                statusText = "NOT MATCHED"
                statusBg = RGB(255, 199, 206)
                statusFg = RGB(156, 0, 6)
            End If

            For c = 1 To nc1
                wsOut.Cells(outRow, e1Start + c - 1).Value = arr1(r, c)
            Next c

            If dict2Keys.Exists(rKey) Then
                Dim r2m As Long
                r2m = dict2Keys(rKey)
                If Not IsBlankRow(arr2, r2m, nc2) Then
                    For c = 1 To nc2
                        wsOut.Cells(outRow, e2Start + c - 1).Value = arr2(r2m, c)
                    Next c
                End If
            End If

            With wsOut.Cells(outRow, statusColOut)
                .Value = statusText
                .Interior.Color = statusBg
                .Font.Color = statusFg
                .Font.Bold = True
            End With
            outRow = outRow + 1

SkipE1Row:
        Next rKey

        For Each rKey In dict2Keys.Keys
            If Not dict1Keys.Exists(rKey) Then
                r = dict2Keys(rKey)
                If IsBlankRow(arr2, r, nc2) Then GoTo SkipE2Row

                For c = 1 To nc2
                    wsOut.Cells(outRow, e2Start + c - 1).Value = arr2(r, c)
                Next c
                With wsOut.Cells(outRow, statusColOut)
                    .Value = "NOT MATCHED"
                    .Interior.Color = RGB(255, 199, 206)
                    .Font.Color = RGB(156, 0, 6)
                    .Font.Bold = True
                End With
                outRow = outRow + 1
SkipE2Row:
            End If
        Next rKey

        wsOut.Columns.AutoFit

        ' Apply borders to output table
        ApplyTableBorders wsOut, 1, e1Start, outRow - 1, e1Start + nc1 - 1
        ApplyTableBorders wsOut, 1, statusColOut, outRow - 1, statusColOut
        ApplyTableBorders wsOut, 1, e2Start, outRow - 1, e2Start + nc2 - 1

        ' Apply filter only on columns that have values
        If wsOut.AutoFilterMode Then wsOut.AutoFilterMode = False
        ApplySmartFilter wsOut, 2, e1Start, nc1, statusColOut, e2Start, nc2

NextSheet:
    Next shtName

    ' Apply borders to summary table
    If summaryRow > 2 Then
        ApplyTableBorders wsSummary, 1, 1, summaryRow - 1, 7
    End If

    wsSummary.Columns.AutoFit
    If wsSummary.AutoFilterMode Then wsSummary.AutoFilterMode = False
    wsSummary.Range("A1:G1").AutoFilter
    wsSummary.Activate

    wb1.Close False
    wb2.Close False

CleanExit:
    Application.Calculation = xlCalculationAutomatic
    Application.EnableEvents = True
    Application.ScreenUpdating = True
    Application.DisplayAlerts = True

    If summaryRow > 2 Then
        MsgBox "Comparison completed successfully!" & vbCrLf & _
               "Results in Summary sheet and individual tabs.", vbInformation, "Done"
    End If

End Sub

'==============================
' Apply outer and inner borders to a table range
'==============================
Private Sub ApplyTableBorders(ws As Worksheet, startRow As Long, startCol As Long, _
                               endRow As Long, endCol As Long)
    If endRow < startRow Or endCol < startCol Then Exit Sub

    Dim tbl As Range
    Set tbl = ws.Range(ws.Cells(startRow, startCol), ws.Cells(endRow, endCol))

    ' Outer border - thick
    With tbl.Borders(xlEdgeLeft)
        .LineStyle = xlContinuous : .Weight = xlMedium : .Color = RGB(0, 0, 0)
    End With
    With tbl.Borders(xlEdgeRight)
        .LineStyle = xlContinuous : .Weight = xlMedium : .Color = RGB(0, 0, 0)
    End With
    With tbl.Borders(xlEdgeTop)
        .LineStyle = xlContinuous : .Weight = xlMedium : .Color = RGB(0, 0, 0)
    End With
    With tbl.Borders(xlEdgeBottom)
        .LineStyle = xlContinuous : .Weight = xlMedium : .Color = RGB(0, 0, 0)
    End With

    ' Inner borders - thin
    With tbl.Borders(xlInsideHorizontal)
        .LineStyle = xlContinuous : .Weight = xlThin : .Color = RGB(180, 180, 180)
    End With
    If endCol > startCol Then
        With tbl.Borders(xlInsideVertical)
            .LineStyle = xlContinuous : .Weight = xlThin : .Color = RGB(180, 180, 180)
        End With
    End If
End Sub

'==============================
' Apply filter only on columns that have at least one value in data rows
'==============================
Private Sub ApplySmartFilter(ws As Worksheet, headerRow As Long, _
                              e1Start As Long, nc1 As Long, _
                              statusCol As Long, _
                              e2Start As Long, nc2 As Long)

    Dim lastDataRow As Long
    Dim fc As Range
    On Error Resume Next
    Set fc = ws.Cells.Find("*", SearchOrder:=xlByRows, SearchDirection:=xlPrevious)
    On Error GoTo 0
    If fc Is Nothing Then Exit Sub
    lastDataRow = fc.Row
    If lastDataRow <= headerRow Then Exit Sub

    ' Collect columns that have at least one non-empty data cell
    Dim colsWithData As Object
    Set colsWithData = CreateObject("Scripting.Dictionary")

    Dim c As Long, r As Long

    ' Check Excel1 columns
    For c = e1Start To e1Start + nc1 - 1
        For r = headerRow + 1 To lastDataRow
            If Trim(CStr(ws.Cells(r, c).Value)) <> "" Then
                If Not colsWithData.Exists(c) Then colsWithData.Add c, 1
                Exit For
            End If
        Next r
    Next c

    ' Check Status column
    For r = headerRow + 1 To lastDataRow
        If Trim(CStr(ws.Cells(r, statusCol).Value)) <> "" Then
            If Not colsWithData.Exists(statusCol) Then colsWithData.Add statusCol, 1
            Exit For
        End If
    Next r

    ' Check Excel2 columns
    For c = e2Start To e2Start + nc2 - 1
        For r = headerRow + 1 To lastDataRow
            If Trim(CStr(ws.Cells(r, c).Value)) <> "" Then
                If Not colsWithData.Exists(c) Then colsWithData.Add c, 1
                Exit For
            End If
        Next r
    Next c

    ' Apply autofilter only to header cells of columns that have data
    Dim colKey As Variant
    For Each colKey In colsWithData.Keys
        ws.Cells(headerRow, colKey).AutoFilter Field:=1
    Next colKey

    ' Proper approach - build union of header cells with data and apply filter
    If ws.AutoFilterMode Then ws.AutoFilterMode = False

    Dim firstCol As Long, lastCol As Long
    firstCol = e1Start
    lastCol = e2Start + nc2 - 1

    ' Apply filter to full header row range but only where data exists
    Dim filterCols As Range
    For Each colKey In colsWithData.Keys
        If filterCols Is Nothing Then
            Set filterCols = ws.Cells(headerRow, colKey)
        Else
            Set filterCols = Union(filterCols, ws.Cells(headerRow, colKey))
        End If
    Next colKey

    If Not filterCols Is Nothing Then
        filterCols.AutoFilter
    End If

End Sub

'==============================
' Write summary row
'==============================
Private Sub WriteSummaryRow(ws As Worksheet, rowNum As Long, shtName As Variant, _
                             existsIn1 As Boolean, existsIn2 As Boolean, _
                             dataRows1 As Long, dataRows2 As Long, _
                             matchedCount As Long, factorMismatchCount As Long, _
                             notMatchedCount As Long, analystView As String)

    ws.Cells(rowNum, 1).Value = IIf(existsIn1, CStr(shtName), "NA")
    ws.Cells(rowNum, 2).Value = IIf(existsIn2, CStr(shtName), "NA")
    ws.Cells(rowNum, 3).Value = analystView
    ws.Cells(rowNum, 4).Value = dataRows1
    ws.Cells(rowNum, 5).Value = dataRows2
    ws.Cells(rowNum, 6).Value = matchedCount
    ws.Cells(rowNum, 7).Value = ""

    Dim analystCell As Range
    Set analystCell = ws.Cells(rowNum, 3)

    Select Case analystView
        Case "Validated"
            analystCell.Interior.Color = RGB(198, 239, 206)
            analystCell.Font.Color = RGB(0, 97, 0)
            analystCell.Font.Bold = True
        Case "Manual Validation Required"
            analystCell.Interior.Color = RGB(255, 235, 156)
            analystCell.Font.Color = RGB(156, 87, 0)
            analystCell.Font.Bold = True
        Case "Page Not Found"
            analystCell.Interior.Color = RGB(255, 199, 206)
            analystCell.Font.Color = RGB(156, 0, 6)
            analystCell.Font.Bold = True
    End Select

End Sub

'==============================
' Read sheet into 2D array skipping blank rows
'==============================
Private Function ReadSheetArray(ws As Worksheet) As Variant
    Dim fc As Range
    Dim lastRow As Long, lastCol As Long

    On Error Resume Next
    Set fc = ws.Cells.Find("*", SearchOrder:=xlByRows, SearchDirection:=xlPrevious)
    On Error GoTo 0
    If fc Is Nothing Then ReadSheetArray = Empty : Exit Function
    lastRow = fc.Row

    On Error Resume Next
    Set fc = ws.Cells.Find("*", SearchOrder:=xlByColumns, SearchDirection:=xlPrevious)
    On Error GoTo 0
    lastCol = fc.Column

    Dim nonBlankCount As Long
    nonBlankCount = 0
    Dim r As Long, c As Long
    Dim hasData As Boolean

    For r = 1 To lastRow
        hasData = False
        For c = 1 To lastCol
            If Trim(ws.Cells(r, c).Text) <> "" Then
                hasData = True
                Exit For
            End If
        Next c
        If hasData Then nonBlankCount = nonBlankCount + 1
    Next r

    If nonBlankCount = 0 Then ReadSheetArray = Empty : Exit Function

    Dim result() As Variant
    ReDim result(1 To nonBlankCount, 1 To lastCol)
    Dim outR As Long
    outR = 0

    For r = 1 To lastRow
        hasData = False
        For c = 1 To lastCol
            If Trim(ws.Cells(r, c).Text) <> "" Then
                hasData = True
                Exit For
            End If
        Next c
        If hasData Then
            outR = outR + 1
            For c = 1 To lastCol
                result(outR, c) = Trim(ws.Cells(r, c).Text)
            Next c
        End If
    Next r

    ReadSheetArray = result
End Function

'==============================
' Normalize value
'==============================
Private Function NormalizeVal(v As Variant) As String
    Dim s As String
    s = Trim(CStr(v))
    s = Replace(s, ",", "")
    If IsNumeric(s) And s <> "" Then
        NormalizeVal = CStr(CDbl(s))
    Else
        NormalizeVal = Trim(LCase(s))
    End If
End Function

'==============================
' Blank row check
'==============================
Private Function IsBlankRow(arr As Variant, rowIdx As Long, numCols As Long) As Boolean
    Dim c As Long
    For c = 1 To numCols
        If Trim(CStr(arr(rowIdx, c))) <> "" Then
            IsBlankRow = False
            Exit Function
        End If
    Next c
    IsBlankRow = True
End Function

'==============================
' Build key from all columns
'==============================
Private Function BuildKeyFromArray(arr As Variant, rowIdx As Long, numCols As Long) As String
    Dim c As Long, s As String
    s = ""
    For c = 1 To numCols
        s = s & "|" & NormalizeVal(arr(rowIdx, c))
    Next c
    BuildKeyFromArray = s
End Function

'==============================
' Build key skipping Factor column
'==============================
Private Function BuildKeySkipCol(arr As Variant, rowIdx As Long, numCols As Long, skipCol As Long) As String
    Dim c As Long, s As String
    s = ""
    For c = 1 To numCols
        If c <> skipCol Then s = s & "|" & NormalizeVal(arr(rowIdx, c))
    Next c
    BuildKeySkipCol = s
End Function

'==============================
' Write header row blue styling
'==============================
Private Sub WriteHeaderRow(ws As Worksheet, arr As Variant, rowIdx As Long, startCol As Long, numCols As Long)
    Dim c As Long
    For c = 1 To numCols
        With ws.Cells(rowIdx, startCol + c - 1)
            .Value = arr(1, c)
            .Font.Bold = True
            .Interior.Color = RGB(68, 114, 196)
            .Font.Color = RGB(255, 255, 255)
        End With
    Next c
End Sub

'==============================
' Write label cell
'==============================
Private Sub WriteLabel(ws As Worksheet, rowIdx As Long, colIdx As Long, labelText As String, bgColor As Long)
    With ws.Cells(rowIdx, colIdx)
        .Value = labelText
        .Font.Bold = True
        .Interior.Color = bgColor
        .Font.Color = RGB(255, 255, 255)
    End With
End Sub

'==============================
' Sheet exists check
'==============================
Private Function WorksheetExists(sheetName As String, wb As Workbook) As Boolean
    Dim ws As Worksheet
    On Error Resume Next
    Set ws = wb.Worksheets(sheetName)
    On Error GoTo 0
    WorksheetExists = Not (ws Is Nothing)
End Function

'==============================
' Safe sheet name
'==============================
Private Function SafeSheetName(baseName As String, wb As Workbook) As String
    Dim nm As String, i As Long
    nm = Replace(baseName, "/", "-")
    nm = Replace(nm, "\", "-")
    nm = Replace(nm, "?", "")
    nm = Replace(nm, "*", "")
    nm = Replace(nm, "[", "(")
    nm = Replace(nm, "]", ")")
    nm = Replace(nm, ":", "-")
    nm = Left(nm, 31)
    If Not WorksheetExists(nm, wb) Then SafeSheetName = nm : Exit Function
    i = 1
    Do While WorksheetExists(Left(nm, 28) & "_" & i, wb)
        i = i + 1
        If i > 999 Then Exit Do
    Loop
    SafeSheetName = Left(nm, 28) & "_" & i
End Function
