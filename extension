<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    body {
      width: 260px;
      font-family: Segoe UI, Arial, sans-serif;
      padding: 14px;
    }
    h3 {
      margin: 0 0 10px 0;
      font-size: 15px;
    }
    button {
      width: 100%;
      padding: 9px;
      font-size: 14px;
      cursor: pointer;
      background: #0f6cbd;
      color: white;
      border: none;
      border-radius: 4px;
    }
    button:hover {
      background: #0b5aa3;
    }
    #status {
      margin-top: 10px;
      font-size: 12px;
      color: #555;
      min-height: 16px;
    }
  </style>
</head>
<body>
  <h3>Extract Page to Excel</h3>
  <button id="extractBtn">Extract &amp; Download</button>
  <div id="status"></div>
  <script src="popup.js"></script>
</body>
</html>
